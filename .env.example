# ── LLM provider keys (at least one required) ────────────────────────
# ntrp auto-selects models based on the provider key you set.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# or add custom models via ~/.ntrp/models.json
# OPENROUTER_API_KEY=sk-or-...

# ── Model overrides (optional — auto-detected from provider key) ─────
# NTRP_CHAT_MODEL=claude-sonnet-4-6
# NTRP_MEMORY_MODEL=gemini-3-flash-preview
# NTRP_EXPLORE_MODEL=gemini-3-flash-preview
# NTRP_EMBEDDING_MODEL=text-embedding-3-small

# ── Optional integrations ────────────────────────────────────────────
# Exa.ai web search
# EXA_API_KEY=...
# WEB_SEARCH=auto  # auto|exa|ddgs|none

# Telegram notifications
# TELEGRAM_BOT_TOKEN=...

# Obsidian vault path
# NTRP_VAULT_PATH=/path/to/your/vault

# Browser history (chrome, safari, arc)
# NTRP_BROWSER=chrome
# NTRP_BROWSER_DAYS=30

# Gmail & Calendar (requires Google OAuth setup)
# NTRP_GMAIL=true
# NTRP_CALENDAR=true

# ── API auth ──────────────────────────────────────────────────────────
# API key is auto-generated on first `ntrp serve` and printed once.
# Use `ntrp serve --reset-key` to regenerate.
